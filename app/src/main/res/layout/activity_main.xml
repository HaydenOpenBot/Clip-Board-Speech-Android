<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <!-- Title block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/onSurface"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textSize="11sp"
                android:textColor="@color/onSurfaceVariant" />
        </LinearLayout>

        <!-- Back arrow button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            android:padding="8dp"
            android:layout_marginEnd="4dp" />

        <!-- Paste icon button -->
        <ImageButton
            android:id="@+id/btnPaste"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_paste_button"
            android:src="@drawable/ic_paste"
            android:contentDescription="@string/btn_paste"
            android:padding="8dp"
            android:layout_marginEnd="8dp" />
    </LinearLayout>

    <!-- Divider below app bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outlineVariant" />

    <!-- Text area section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <!-- EditText for input -->
        <EditText
            android:id="@+id/etInput"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_text_area"
            android:hint="@string/hint_enter_text"
            android:textColor="@color/onSurface"
            android:textColorHint="@color/hintText"
            android:textSize="16sp"
            android:padding="14dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:scrollbars="vertical"
            android:overScrollMode="always" />

        <!-- Read-along TextView (shown during speech, GONE by default) -->
        <TextView
            android:id="@+id/tvReadAlong"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_read_along"
            android:textColor="@color/onSurface"
            android:textSize="17sp"
            android:padding="14dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:lineSpacingMultiplier="1.7"
            android:gravity="top|start"
            android:scrollbars="vertical"
            android:overScrollMode="always"
            android:visibility="gone" />

        <!-- Inline Summary Panel (GONE by default) -->
        <LinearLayout
            android:id="@+id/summaryPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_summary_panel"
            android:layout_marginTop="8dp"
            android:padding="14dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <!-- Icon box -->
                <FrameLayout
                    android:id="@+id/summaryIconBox"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_summary_icon_box"
                    android:layout_marginEnd="10dp">

                    <ImageView
                        android:id="@+id/summaryIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_summary"
                        android:importantForAccessibility="no" />
                </FrameLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/summaryPanelTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Summary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/onSurface" />

                <!-- Regenerate button (AI summaries only) -->
                <ImageButton
                    android:id="@+id/btnRegenerateAiSummary"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_refresh"
                    android:contentDescription="Regenerate AI summary"
                    android:padding="4dp"
                    android:layout_marginEnd="4dp"
                    android:visibility="gone" />

                <!-- Dismiss button -->
                <ImageButton
                    android:id="@+id/btnDismissSummary"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Dismiss summary"
                    android:padding="4dp" />
            </LinearLayout>

            <!-- Loading state -->
            <LinearLayout
                android:id="@+id/summaryLoadingRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:indeterminate="true"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generating AI summary…"
                    android:textSize="13sp"
                    android:textColor="@color/onSurfaceVariant" />
            </LinearLayout>

            <!-- Summary text – fixed 200dp height forces ScrollView to actually scroll -->
            <ScrollView
                android:id="@+id/scrollSummaryContent"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="12dp"
                android:fillViewport="false"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSummaryContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/onSurface"
                    android:lineSpacingMultiplier="1.7"
                    android:padding="2dp" />

            </ScrollView>

            <!-- Action buttons row -->
            <LinearLayout
                android:id="@+id/summaryActionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <!-- Use for TTS button -->
                <Button
                    android:id="@+id/btnSummaryUseTts"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_use_tts_button"
                    android:text="Use for TTS"
                    android:textColor="@color/onSurface"
                    android:textSize="12sp"
                    android:drawableStart="@drawable/ic_speak"
                    android:drawablePadding="4dp"
                    android:layout_marginEnd="8dp"
                    android:stateListAnimator="@null" />

                <!-- Copy button -->
                <Button
                    android:id="@+id/btnSummaryCopy"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_copy_button"
                    android:text="Copy"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:drawableStart="@drawable/ic_copy"
                    android:drawablePadding="4dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

        </LinearLayout>

        <!-- Bottom row: char count | Save | Clear -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tvCharCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/onSurfaceVariant"
                android:text="0 chars" />

            <ImageButton
                android:id="@+id/btnSave"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_action_button"
                android:src="@drawable/ic_save"
                android:contentDescription="@string/btn_save"
                android:padding="6dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnClear"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_action_button"
                android:src="@drawable/ic_clear"
                android:contentDescription="@string/btn_clear"
                android:padding="6dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Summary buttons row (visible when text non-empty and not speaking) -->
        <LinearLayout
            android:id="@+id/rowSummaryButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnAiSummary"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_ai_summary_button"
                android:text="AI Summary"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:drawableStart="@drawable/ic_ai"
                android:drawablePadding="4dp"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnProcessNote"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_summary_button"
                android:text="📝 筆記"
                android:textColor="@color/onSurfaceVariant"
                android:textSize="11sp"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnRecallAiSummary"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_summary_button"
                android:text="Recall AI"
                android:textColor="@color/onSurfaceVariant"
                android:textSize="11sp"
                android:drawableStart="@drawable/ic_history"
                android:drawablePadding="4dp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider above controls -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outlineVariant" />

    <!-- Controls panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingTop="10dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <!-- Speed slider row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="@string/label_speed"
                android:textSize="13sp"
                android:textColor="@color/onSurfaceVariant" />

            <SeekBar
                android:id="@+id/seekSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="15"
                android:progress="9"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvSpeedValue"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="1.4×"
                android:textSize="13sp"
                android:textColor="@color/onSurface"
                android:gravity="end" />
        </LinearLayout>

        <!-- Pitch slider row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:text="@string/label_pitch"
                android:textSize="13sp"
                android:textColor="@color/onSurfaceVariant" />

            <SeekBar
                android:id="@+id/seekPitch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="15"
                android:progress="5"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvPitchValue"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="1.0"
                android:textSize="13sp"
                android:textColor="@color/onSurface"
                android:gravity="end" />
        </LinearLayout>

        <!-- Voice selector button -->
        <LinearLayout
            android:id="@+id/btnVoiceSelector"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_voice_selector"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_voice_selector">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_voice"
                android:textSize="13sp"
                android:textColor="@color/onSurfaceVariant" />

            <TextView
                android:id="@+id/tvVoiceName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="@string/label_select_voice"
                android:textSize="13sp"
                android:textColor="@color/onSurface"
                android:gravity="end"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_dropdown"
                android:layout_marginStart="4dp"
                android:importantForAccessibility="no" />
        </LinearLayout>

        <!-- Speak button -->
        <Button
            android:id="@+id/btnSpeak"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_speak_button"
            android:text="@string/btn_speak"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_speak"
            android:drawablePadding="8dp"
            android:elevation="2dp"
            android:stateListAnimator="@null" />

        <!-- Pause + Stop row (GONE by default) -->
        <LinearLayout
            android:id="@+id/rowPauseStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <!-- Pause/Resume button -->
            <Button
                android:id="@+id/btnPauseResume"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pause_button"
                android:text="@string/btn_pause"
                android:textColor="@color/onSurface"
                android:textSize="14sp"
                android:drawableStart="@drawable/ic_pause"
                android:drawablePadding="6dp"
                android:layout_marginEnd="8dp"
                android:stateListAnimator="@null" />

            <!-- Stop button -->
            <ImageButton
                android:id="@+id/btnStop"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_stop_button"
                android:src="@drawable/ic_stop"
                android:contentDescription="@string/btn_stop"
                android:padding="12dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
